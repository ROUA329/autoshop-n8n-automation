    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO order_items (\n  order_id,\n  product_id,\n  quantity,\n  unit_price,\n  line_total\n)\nSELECT\n  {{ $json.order_id }},\n  id,\n  {{ $json.quantity }},\n  {{ $json.unit_price }},\n  {{ $json.line_total }}\nFROM products\nWHERE product_code = '{{ $json.product_code }}'\nRETURNING \n  id,\n  product_id,\n  '{{ $json.product_code }}' as product_code,\n  {{ $json.quantity }} as ordered_quantity;",
        "options": {}
      },
