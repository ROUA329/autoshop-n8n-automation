    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO customers (full_name, email, phone)\nVALUES (\n  '{{ $json.order.customer.full_name }}',\n  '{{ $json.order.customer.email }}',\n  '{{ $json.order.customer.phone }}'\n)\nRETURNING id;",
        "options": {}
