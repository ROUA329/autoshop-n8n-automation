    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n  p.product_name,\n  SUM(oi.quantity) AS total_sold,\n  SUM(oi.line_total) AS total_revenue\nFROM order_items oi\nJOIN products p ON p.id = oi.product_id\nJOIN orders o ON o.id = oi.order_id\nGROUP BY p.product_name\nORDER BY total_sold DESC\nLIMIT 5;",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        -112,
        -32
      ],
      "id": "1e09c264-74cb-4e7c-86a1-bfb36234293b",
      "name": "Get Top Products",
      "credentials": {
