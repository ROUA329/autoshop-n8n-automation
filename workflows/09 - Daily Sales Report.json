          "id": "N03WY2oeHmlYaQQf",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n  product_name,\n  stock_quantity,\n  minimum_stock\nFROM products\nWHERE stock_quantity <= minimum_stock\nORDER BY stock_quantity ASC;",
        "options": {}
      },
